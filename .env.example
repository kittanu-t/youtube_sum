# --- LLM Configuration ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest

# --- Optional: OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Optional: Gemini ---
GEMINI_API_KEY=

# --- Provider: ollama | openai | gemini ---
LLM_PROVIDER=ollama

# --- App Settings ---
DATABASE_PATH=./youtube_sum.db
OUTPUT_DIR=./output
DEFAULT_LANGUAGE=en
MAX_TRANSCRIPT_LENGTH=60000
CHUNK_SIZE=8000
CHUNK_OVERLAP=500

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
